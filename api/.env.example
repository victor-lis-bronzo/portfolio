# Environment Variables

Copy this file to `.env` and fill in the values.

PORT=3333
NODE_ENV=development

# Database configuration
DATABASE_URL=postgresql://portfolio:portfolio123@localhost:5433/portfolio_db

# Firebase configuration
FIREBASE_STORAGE_BUCKET=portfolio-project.appspot.com
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
FIREBASE_SERVICE_ACCOUNT_PATH=./infra/firebase/service-account.json
