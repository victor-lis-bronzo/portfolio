{
  "name": "@portfolio/core",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js",
      "default": "./dist/services/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "db:seed": "tsx --tsconfig tsconfig.json ./src/seed.ts"
  },
  "dependencies": {
    "@portfolio/database": "workspace:*",
    "@portfolio/packages": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "tsup": "^8.5.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
